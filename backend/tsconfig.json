{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",

    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"]
    
  },

  "include": ["src"]
}